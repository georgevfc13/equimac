# Local routing for EQUIMAC

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Running under: http://localhost/equimac/...
  RewriteBase /equimac/

  # Serve assets from /public transparently:
  RewriteRule ^assets/(.*)$ public/assets/$1 [L]

  # If physical file/dir exists, serve it.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Front controller (always)
  RewriteRule ^ public/index.php [L]
</IfModule>

# Hide dotfiles
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

DirectoryIndex index.php
